// HR Loop - Prisma Schema
// Comprehensive HR system for 40-branch mobile phone retail chain

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  OWNER
  MANAGER
  STAFF

  @@map("user_role")
}

enum EmploymentType {
  FULL_TIME
  HOURLY

  @@map("employment_type")
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
  COMPLETED

  @@map("shift_status")
}

enum AttendanceType {
  CLOCK_IN
  CLOCK_OUT
  BREAK_START
  BREAK_END

  @@map("attendance_type")
}

enum LeaveType {
  ANNUAL
  SICK
  EMERGENCY
  UNPAID

  @@map("leave_type")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED

  @@map("leave_status")
}

enum DisputeStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("dispute_status")
}

enum SwapStatus {
  PENDING_REPLACEMENT    // Waiting for replacement employee to accept
  PENDING_MANAGER        // Replacement accepted, waiting for manager approval
  APPROVED               // Manager approved — swap confirmed
  REJECTED_REPLACEMENT   // Replacement declined
  REJECTED_MANAGER       // Manager rejected
  CANCELLED              // Requester cancelled

  @@map("swap_status")
}

// ============================================================
// BRANCHES
// ============================================================

model Branch {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String   @db.VarChar(150)
  address        String?
  latitude       Float
  longitude      Float
  geofenceRadius Int      @default(50) @map("geofence_radius")
  managerId      String?  @map("manager_id") @db.Uuid

  // Branch operating hours (open/close)
  openTime       String?  @map("open_time") @db.VarChar(5)   // e.g. "09:00"
  closeTime      String?  @map("close_time") @db.VarChar(5)  // e.g. "22:00"

  // Employee shift hours
  shiftStartTime String?  @map("shift_start_time") @db.VarChar(5) // e.g. "09:00"
  shiftEndTime   String?  @map("shift_end_time") @db.VarChar(5)   // e.g. "17:00"

  minStaff       Int      @default(0) @map("min_staff")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  manager        User?              @relation("BranchManager", fields: [managerId], references: [id], onDelete: SetNull)
  users          User[]             @relation("UserPrimaryBranch")
  assignedUsers  UserBranch[]
  shifts         Shift[]
  requirements   BranchRequirement[]

  @@index([managerId], name: "idx_branches_manager")
  @@map("branches")
}

// ============================================================
// USERS
// ============================================================

model User {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName             String   @map("full_name") @db.VarChar(200)
  email                String   @unique @db.VarChar(255)
  passwordHash         String   @map("password_hash")
  role                 UserRole @default(STAFF)
  primaryBranchId      String?  @map("primary_branch_id") @db.Uuid
  phoneNumber          String?  @map("phone_number") @db.VarChar(20)
  socialSecurityNumber  String?  @map("social_security_number") @db.VarChar(20)
  employmentType       EmploymentType @default(FULL_TIME) @map("employment_type")
  isFlexibleSchedule   Boolean  @default(false) @map("is_flexible_schedule")
  isActive             Boolean  @default(true) @map("is_active")

  // WebAuthn biometric fields
  webauthnCredentialId String?  @map("webauthn_credential_id")
  webauthnPublicKey    String?  @map("webauthn_public_key")
  webauthnSignCount    Int      @default(0) @map("webauthn_sign_count")

  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  primaryBranch    Branch?          @relation("UserPrimaryBranch", fields: [primaryBranchId], references: [id], onDelete: SetNull)
  managedBranches  Branch[]         @relation("BranchManager")
  assignedBranches UserBranch[]
  documents        EmployeeDocument[]
  availability     Availability[]
  shifts           Shift[]
  attendanceLogs   AttendanceLog[]
  payrollProfile   PayrollProfile?
  monthlyPayslips  MonthlyPayslip[]
  leaveRequests        LeaveRequest[]   @relation("LeaveRequester")
  reviewedLeaves       LeaveRequest[]   @relation("LeaveReviewer")
  notifications        Notification[]
  activityLogs         ActivityLog[]
  disputes             Dispute[]        @relation("DisputeUser")
  reviewedDisputes     Dispute[]        @relation("DisputeReviewer")
  systemLogs           SystemLog[]
  reviewedAttendance   AttendanceLog[]  @relation("AttendanceReviewer")
  checkoutChecklists   CheckoutChecklist[]
  announcements        Announcement[]
  swapRequests         ShiftSwap[]      @relation("SwapRequester")
  swapReplacements     ShiftSwap[]      @relation("SwapReplacement")
  swapManagerReviews   ShiftSwap[]      @relation("SwapManager")

  @@index([email], name: "idx_users_email")
  @@index([role], name: "idx_users_role")
  @@index([primaryBranchId], name: "idx_users_primary_branch")
  @@index([isActive], name: "idx_users_active")
  @@map("users")
}

// ============================================================
// USER-BRANCH ASSIGNMENT — Many-to-many: branches an employee can work at
// ============================================================

model UserBranch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId], name: "idx_user_branch_user")
  @@index([branchId], name: "idx_user_branch_branch")
  @@map("user_branches")
}

// ============================================================
// EMPLOYEE DOCUMENTS — Hiring paperwork file uploads
// ============================================================

model EmployeeDocument {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  fileName     String   @map("file_name") @db.VarChar(255)
  originalName String   @map("original_name") @db.VarChar(255)
  fileSize     Int      @map("file_size")
  mimeType     String   @map("mime_type") @db.VarChar(100)
  uploadedAt   DateTime @default(now()) @map("uploaded_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_employee_docs_user")
  @@map("employee_documents")
}

// ============================================================
// BRANCH REQUIREMENTS - Staffing needs per branch per day
// ============================================================

model BranchRequirement {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId      String   @map("branch_id") @db.Uuid
  dayOfWeek     Int      @map("day_of_week") @db.SmallInt // 0=Sunday, 6=Saturday
  requiredStaff Int      @default(1) @map("required_staff")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, dayOfWeek])
  @@index([branchId], name: "idx_branch_req_branch")
  @@index([dayOfWeek], name: "idx_branch_req_day")
  @@index([branchId, dayOfWeek], name: "idx_branch_req_branch_day")
  @@map("branch_requirements")
}

// ============================================================
// AVAILABILITY - Weekly availability per hourly employee
// ============================================================

model Availability {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  dayOfWeek Int      @map("day_of_week") @db.SmallInt // 0=Sunday, 6=Saturday
  startTime String   @map("start_time") @db.VarChar(5) // "09:00"
  endTime   String   @map("end_time") @db.VarChar(5)   // "17:00"
  lockedUntil DateTime? @map("locked_until") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
  @@index([userId], name: "idx_availability_user")
  @@index([dayOfWeek], name: "idx_availability_day")
  @@map("availability")
}

// ============================================================
// SHIFTS - Master schedule for all 40 branches
// ============================================================

model Shift {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  branchId       String      @map("branch_id") @db.Uuid
  date           DateTime    @db.Date
  scheduledStart DateTime    @map("scheduled_start") @db.Timestamptz
  scheduledEnd   DateTime    @map("scheduled_end") @db.Timestamptz
  status         ShiftStatus @default(DRAFT)
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  attendanceLogs      AttendanceLog[]
  disputes            Dispute[]
  checkoutChecklists  CheckoutChecklist[]
  shiftSwaps          ShiftSwap[]

  @@index([userId], name: "idx_shifts_user")
  @@index([branchId], name: "idx_shifts_branch")
  @@index([date], name: "idx_shifts_date")
  @@index([status], name: "idx_shifts_status")
  @@index([branchId, date], name: "idx_shifts_branch_date")
  @@index([userId, date], name: "idx_shifts_user_date")
  @@map("shifts")
}

// ============================================================
// ATTENDANCE LOGS - High-frequency write-optimized
// ============================================================

model AttendanceLog {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  shiftId       String?        @map("shift_id") @db.Uuid
  type          AttendanceType
  timestamp       DateTime       @default(now()) @db.Timestamptz
  latitude        Float?
  longitude       Float?
  isWithinFence   Boolean        @default(false) @map("is_within_fence")

  // Manual override fields (GPS drift helper)
  overrideStatus  String?        @map("override_status") @db.VarChar(20)
  overridePhotoUrl String?       @map("override_photo_url")
  overrideReason  String?        @map("override_reason")
  reviewedById    String?        @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime?      @map("reviewed_at") @db.Timestamptz

  // Relations
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift      Shift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  reviewedBy User?  @relation("AttendanceReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId], name: "idx_attendance_user")
  @@index([shiftId], name: "idx_attendance_shift")
  @@index([timestamp], name: "idx_attendance_timestamp")
  @@index([type], name: "idx_attendance_type")
  @@index([userId, shiftId], name: "idx_attendance_user_shift")
  @@map("attendance_logs")
}

// ============================================================
// CHECKOUT CHECKLIST - Must complete before clock-out
// ============================================================

model CheckoutChecklist {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftId           String   @map("shift_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  inventoryCount    Boolean  @default(false) @map("inventory_count")
  newMerchandise    Boolean? @map("new_merchandise")         // true=yes, false=no, null=not answered
  insurancePhones   Boolean  @default(false) @map("insurance_phones")
  completedAt       DateTime? @map("completed_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shiftId, userId])
  @@index([userId], name: "idx_checkout_checklist_user")
  @@map("checkout_checklists")
}

// ============================================================
// PAYROLL PROFILES - Financial settings per employee
// ============================================================

model PayrollProfile {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  baseSalary               Decimal  @default(0.00) @map("base_salary") @db.Decimal(12, 2)
  hourlyRate               Decimal  @default(0.00) @map("hourly_rate") @db.Decimal(8, 2)
  overtimeRate             Decimal  @default(0.00) @map("overtime_rate") @db.Decimal(8, 2)
  transportationAllowance  Decimal  @default(0.00) @map("transportation_allowance") @db.Decimal(10, 2)
  latePenaltyPerMinute     Decimal  @default(0.00) @map("late_penalty_per_minute") @db.Decimal(6, 2)
  gracePeriodMinutes   Int      @default(5) @map("grace_period_minutes")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_payroll_user")
  @@map("payroll_profiles")
}

// ============================================================
// MONTHLY PAYSLIPS
// ============================================================

model MonthlyPayslip {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  month                 Int      @db.SmallInt
  year                  Int      @db.SmallInt
  totalShifts           Int      @default(0) @map("total_shifts")
  totalHoursWorked      Decimal  @default(0.00) @map("total_hours_worked") @db.Decimal(8, 2)
  totalOvertimeHours    Decimal  @default(0.00) @map("total_overtime_hours") @db.Decimal(8, 2)
  totalLateMinutes      Decimal  @default(0.00) @map("total_late_minutes") @db.Decimal(8, 2)
  totalEarlyLeaveMinutes Decimal @default(0.00) @map("total_early_leave_minutes") @db.Decimal(8, 2)
  totalAbsentDays       Int      @default(0) @map("total_absent_days")
  totalDeductions       Decimal  @default(0.00) @map("total_deductions") @db.Decimal(12, 2)
  totalBonuses          Decimal  @default(0.00) @map("total_bonuses") @db.Decimal(12, 2)
  finalNetSalary        Decimal  @default(0.00) @map("final_net_salary") @db.Decimal(12, 2)
  isLocked              Boolean  @default(false) @map("is_locked")
  generatedAt           DateTime @default(now()) @map("generated_at") @db.Timestamptz

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  disputes Dispute[]

  @@unique([userId, month, year])
  @@index([userId], name: "idx_payslips_user")
  @@index([month, year], name: "idx_payslips_month_year")
  @@index([userId, year, month], name: "idx_payslips_user_period")
  @@map("monthly_payslips")
}

// ============================================================
// LEAVE REQUESTS
// ============================================================

model LeaveRequest {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  type         LeaveType
  status       LeaveStatus @default(PENDING)
  startDate    DateTime    @map("start_date") @db.Date
  endDate      DateTime    @map("end_date") @db.Date
  reason       String?
  reviewerId   String?     @map("reviewer_id") @db.Uuid
  reviewedAt   DateTime?   @map("reviewed_at") @db.Timestamptz
  reviewerNote String?     @map("reviewer_note")
  isPaid       Boolean     @default(true) @map("is_paid")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user     User  @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("LeaveReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([userId], name: "idx_leave_user")
  @@index([status], name: "idx_leave_status")
  @@index([startDate, endDate], name: "idx_leave_dates")
  @@index([userId, startDate, endDate], name: "idx_leave_user_dates")
  @@map("leave_requests")
}

// ============================================================
// GLOBAL SETTINGS
// ============================================================

model GlobalSetting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       String
  label       String   @db.VarChar(200)
  description String?
  category    String   @default("general") @db.VarChar(50)
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([key], name: "idx_settings_key")
  @@index([category], name: "idx_settings_category")
  @@map("global_settings")
}

// ============================================================
// ACTIVITY LOGS (Audit Trail)
// ============================================================

model ActivityLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid
  actorName   String   @map("actor_name") @db.VarChar(200)
  action      String   @db.VarChar(100)
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    String?  @map("entity_id") @db.VarChar(100)
  description String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId], name: "idx_activity_actor")
  @@index([action], name: "idx_activity_action")
  @@index([entityType, entityId], name: "idx_activity_entity")
  @@index([createdAt(sort: Desc)], name: "idx_activity_created")
  @@map("activity_logs")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(200)
  message   String
  type      String   @default("info") @db.VarChar(50)
  isRead    Boolean  @default(false) @map("is_read")
  link      String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_notifications_user")
  @@index([userId, isRead], name: "idx_notifications_unread")
  @@map("notifications")
}

// ============================================================
// DISPUTES - Penalty dispute system
// ============================================================

model Dispute {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  payslipId      String        @map("payslip_id") @db.Uuid
  shiftId        String?       @map("shift_id") @db.Uuid
  disputeType    String        @default("LATE_DEDUCTION") @map("dispute_type") @db.VarChar(50)
  originalAmount Decimal       @default(0.00) @map("original_amount") @db.Decimal(12, 2)
  reason         String
  status         DisputeStatus @default(PENDING)
  adminComment   String?       @map("admin_comment")
  reviewedBy     String?       @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?     @map("reviewed_at") @db.Timestamptz
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user     User           @relation("DisputeUser", fields: [userId], references: [id], onDelete: Cascade)
  payslip  MonthlyPayslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  shift    Shift?         @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  reviewer User?          @relation("DisputeReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId], name: "idx_disputes_user")
  @@index([payslipId], name: "idx_disputes_payslip")
  @@index([status], name: "idx_disputes_status")
  @@index([createdAt(sort: Desc)], name: "idx_disputes_created")
  @@map("disputes")
}

// ============================================================
// SYSTEM LOGS - Immutable audit trail for critical actions
// ============================================================

model SystemLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid
  actionType  String   @map("action_type") @db.VarChar(100)
  targetType  String   @map("target_type") @db.VarChar(50)
  targetId    String?  @map("target_id") @db.VarChar(100)
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent")
  description String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId], name: "idx_system_logs_actor")
  @@index([actionType], name: "idx_system_logs_action")
  @@index([targetType, targetId], name: "idx_system_logs_target")
  @@index([createdAt(sort: Desc)], name: "idx_system_logs_created")
  @@map("system_logs")
}

// ============================================================
// ANNOUNCEMENTS — News feed posts by managers/owners
// ============================================================

model Announcement {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  content     String
  mediaUrl    String?  @map("media_url") @db.VarChar(500)
  mediaType   String?  @map("media_type") @db.VarChar(20) // "image" | "video"
  isPinned    Boolean  @default(false) @map("is_pinned")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)], name: "idx_announcements_created")
  @@index([authorId], name: "idx_announcements_author")
  @@map("announcements")
}

// ============================================================
// SHIFT SWAPS - Two-step approval: replacement → manager
// ============================================================

model ShiftSwap {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterId      String     @map("requester_id") @db.Uuid
  replacementId    String     @map("replacement_id") @db.Uuid
  shiftId          String     @map("shift_id") @db.Uuid
  status           SwapStatus @default(PENDING_REPLACEMENT)
  reason           String?
  replacementNote  String?    @map("replacement_note")
  managerNote      String?    @map("manager_note")
  managerId        String?    @map("manager_id") @db.Uuid
  replacementRespondedAt DateTime? @map("replacement_responded_at") @db.Timestamptz
  managerRespondedAt     DateTime? @map("manager_responded_at") @db.Timestamptz
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  requester   User  @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  replacement User  @relation("SwapReplacement", fields: [replacementId], references: [id], onDelete: Cascade)
  shift       Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  manager     User? @relation("SwapManager", fields: [managerId], references: [id], onDelete: SetNull)

  @@index([requesterId], name: "idx_swap_requester")
  @@index([replacementId], name: "idx_swap_replacement")
  @@index([shiftId], name: "idx_swap_shift")
  @@index([status], name: "idx_swap_status")
  @@index([createdAt(sort: Desc)], name: "idx_swap_created")
  @@map("shift_swaps")
}
